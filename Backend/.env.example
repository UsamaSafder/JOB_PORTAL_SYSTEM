### Backend .env example — copy to .env and set your real values
# SQL Server connection
DB_AUTH_TYPE=sql
DB_USER=sa
DB_PASSWORD=YourStrongPasswordHere
DB_SERVER=localhost
DB_NAME=JobPortalDB
DB_PORT=1433
DB_ENCRYPT=false
DB_TRUST_SERVER_CERTIFICATE=true

# For Windows Authentication instead of SQL login:
# DB_AUTH_TYPE=windows
# DB_CONNECTION_STRING=Data Source=localhost;Integrated Security=True;Initial Catalog=JobPortalDB;Encrypt=False;TrustServerCertificate=True;

# Server settings
PORT=5001
NODE_ENV=development

# JWT - set a secure random value for production
JWT_SECRET=replace-with-a-secure-secret
JWT_EXPIRE=7d

# CORS - comma separated origins allowed for dev, or leave blank to allow all origins
ALLOWED_ORIGINS=http://localhost:4200
